{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the Musaic AI platform.",
      "type": "object",
      "properties": {
        "displayName": { "type": "string", "description": "The user's display name." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "avatar": { "type": "string", "description": "URL to the user's avatar image." },
        "points": { "type": "number", "description": "The user's current token balance." },
        "isPro": { "type": "boolean", "description": "Whether the user has a Pro subscription." },
        "stripeCustomerId": { "type": "string", "description": "The user's Stripe customer ID." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user account was created." }
      },
      "required": ["email", "points"]
    },
    "SmartLink": {
      "title": "Smart Link",
      "description": "A public landing page for an artist.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The ID of the user who owns this link." },
        "slug": { "type": "string", "description": "The unique URL slug for this link." },
        "profileName": { "type": "string", "description": "The artist's display name on the page." },
        "bio": { "type": "string", "description": "A short biography." },
        "socialMedia": { 
          "type": "array", 
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "platform": { "type": "string" },
              "url": { "type": "string" },
              "title": { "type": "string" }
            }
          },
          "description": "List of social media links."
        },
        "selectedAssets": { 
          "type": "array", 
          "items": { "type": "string" }, 
          "description": "List of asset IDs or URLs for the background carousel." 
        },
        "profileImage": { "type": "string", "description": "URL to the profile image." },
        "theme": { "type": "string", "enum": ["glass", "nightclub", "minimal"], "description": "The visual theme of the page." },
        "buttonStyle": { "type": "string", "enum": ["rounded", "square"], "description": "The style of the buttons." },
        "buttonColor": { "type": "string", "description": "The primary color for buttons." },
        "backgroundMotion": { "type": "boolean", "description": "Whether background motion is enabled." },
        "isActive": { "type": "boolean", "description": "Whether the link is publicly accessible." },
        "views": { "type": "number", "description": "Total number of page views." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the link was created." }
      },
      "required": ["userId", "slug", "profileName"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "A record of token usage or purchase.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The user who made the transaction." },
        "amount": { "type": "number", "description": "The amount of tokens added or deducted." },
        "description": { "type": "string", "description": "A description of the transaction." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the transaction occurred." }
      },
      "required": ["userId", "amount", "description"]
    },
    "SmartLinkClick": {
      "title": "Smart Link Click",
      "description": "A record of a click on a social link.",
      "type": "object",
      "properties": {
        "smartLinkId": { "type": "string", "description": "The ID of the smart link." },
        "platform": { "type": "string", "description": "The platform that was clicked." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the click occurred." }
      },
      "required": ["smartLinkId", "platform"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Stores user profiles and balances."
    },
    "smartlinks/{slug}": {
      "schema": "SmartLink",
      "description": "Stores smart link configurations, keyed by slug for fast lookup."
    },
    "transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Stores history of token transactions."
    },
    "smart_link_clicks/{clickId}": {
      "schema": "SmartLinkClick",
      "description": "Stores analytics data for link clicks."
    }
  }
}
