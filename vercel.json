{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/**/*.ts": {
      "memory": 1024,
      "maxDuration": 60
    },
    "api/ai/generate-video.ts": {
      "memory": 1024,
      "maxDuration": 300
    },
    "api/webhooks/stripe.ts": {
      "memory": 512,
      "maxDuration": 30
    }
  }
}
